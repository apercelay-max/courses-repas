# Connection string Postgres de Supabase.
# Supabase Dashboard > ton projet > Project Settings > Database > Connection string
# -> onglet "Transaction" (port 6543), copier l'URI et remplacer [YOUR-PASSWORD]
# par le mot de passe de la base défini à la création du projet.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Optionnel : active l'extraction d'ingrédients via Claude au lieu du mode mock.
# ANTHROPIC_API_KEY=sk-ant-...
